# TwoThumbs environment variables
# Copy this file to .env.local and fill in actual values. Never commit .env.local.

# --- Supabase ---
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# --- Google Places / Maps ---
# Get from: Google Cloud Console > APIs & Services > Credentials
# Restrict this key to your Android/iOS package IDs in GCP console.
GOOGLE_MAPS_API_KEY=your-google-api-key-here

# --- AdMob ---
# Get from: https://admob.google.com (app registration, account pending approval)
ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_BANNER_UNIT_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_BANNER_UNIT_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# --- NEVER put service_role key in this file or anywhere the app can read it ---
# service_role goes only into Supabase Edge Function secrets:
#   supabase secrets set SERVICE_ROLE_KEY=...
